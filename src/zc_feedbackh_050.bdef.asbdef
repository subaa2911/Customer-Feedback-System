projection;
strict ( 2 );
use draft;

define behavior for ZC_FEEDBACKH_050 alias Feedback
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Items { create; with draft; }
}

define behavior for ZC_FEEDBACKI_050 alias Items
{
  use update;
  use delete;

  use association _Header { with draft; }
}